{
  "name": "orys",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "ai": "^6.0.77",
      "@ai-sdk/google": "^3.0.0",
      "@ai-sdk/openai": "^3.0.0",
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5.8.3",
      "@types/bun": "^1.3.4",
      "better-auth": "^1.5.2",
      "elysia": "^1.4.22",
      "@elysiajs/cors": "^1.4.1",
      "@elysiajs/eden": "^1.4.6"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @orys/db db:push",
    "db:studio": "turbo -F @orys/db db:studio",
    "db:generate": "turbo -F @orys/db db:generate",
    "db:migrate": "turbo -F @orys/db db:migrate",
    "bots:seed": "bun run --cwd apps/bots seed",
    "bots:bid": "bun run --cwd apps/bots bid",
    "bots:viewers": "bun run --cwd apps/bots viewers",
    "bots:verify": "bun run --cwd apps/bots verify",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@orys/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@orys/config": "workspace:*",
    "@types/bun": "catalog:",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.14",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.2"
}
